NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-random-base64-secret

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lexiconai

# Used to encrypt saved provider API keys.
ENCRYPT_SECRET=replace-with-a-long-random-secret

# OAuth providers
GITHUB_ID=your-github-client-id
GITHUB_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
